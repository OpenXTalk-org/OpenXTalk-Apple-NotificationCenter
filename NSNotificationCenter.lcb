-- private foreign handler objC_NSObjectGetSuperClass(in pNSObj as ObjcId) returns ObjcRetainedId binds to "c:NObject.+superclass:"
private foreign handler objC_NSObjectGetSuperClass(in pNSObj as ObjcId) returns ObjcId binds to "objc:NSObject.superclass"
-- private foreign handler objC_NSObjectGetSuperClass(in pNSObj as ObjcId) returns ObjcRetainedId binds to "c:NObject.+superclass:"
private foreign handler ObjC_NSObjectIsKindOfClass(in pObject as ObjcId, in pClass as ObjcId) returns CBool binds to "objc:NSObject.-isKindOfClass:"

private foreign handler objC_NSObjectSetValueForKey(in pAVAUSampler as ObjcId, in pValue as ObjcId, in pSelector as ObjcId) returns optional ObjcId binds to "objc:NSObject.-setValue:forKey:"
private foreign handler objC_NSObjectGetValueForKey(in pNSObject as ObjcId, in pSelector as ObjcId) returns optional ObjcId binds to "objc:NSObject.-valueForKey:"

---------------------  NSError
private foreign handler objC_NSErrorAlloc() returns ObjcRetainedId binds to "objc:NSError.+alloc"
-- private foreign handler objC_NSErrorAlloc() returns ObjcId binds to "objc:NSError.+alloc"

private foreign handler c_NSClassFromString(in pClassNameString as ObjcId) returns ObjcId binds to "c:NSClassFromString"
private foreign handler c_class_copyPropertyList(in pClass as ObjcId, out pCount as UInt32) returns optional Pointer binds to "c:class_copyPropertyList"

public handler LogNSObjectReflection(in pNSObj as optional ObjcId)
   variable tOSStatus as CSInt
   variable tNSStrObj as optional ObjcId
   variable tNSObjB as optional ObjcId
   variable tStr as optional String
   variable tClass as ObjcId
   variable tPropsCount as optional UInt32
   variable tClassDescription as optional ObjcId
   variable tListNSObj as optional ObjcId
   variable tListOpaquePtr as optional Pointer -- to an array of 'objc_property_t'
   variable tListArray as optional Array
   variable tList as optional List
   variable tString as optional ZStringNative
   variable tCStringPtr as optional Pointer
   variable tSuccess as CBool
   variable rOutArrayPtr as optional Pointer

   if pNSObj is not nothing then
      unsafe
         put objC_NSObjectClassName(pNSObj) into tNSStrObj
         put StringFromNSString(tNSStrObj) into tStr
         log ["Class Name" , tStr]
         put c_NSClassFromString(tNSStrObj) into tClass

         put objC_NSObjectGetSuperClass(pNSObj) into tNSObjB
         put objC_NSObjectClassName(tNSObjB) into tNSStrObj
         put StringFromNSString(tNSStrObj) into tStr
         log ["SuperClass" , tStr]

         put objC_NSObjectGetDescription(pNSObj) into tNSStrObj
         put StringFromNSString(tNSStrObj) into tStr
         log ["Description" , tStr]

         -- GetNSObjectAttributeKeys(pNSObj)
         put ObjC_NSObjectGetAttributeKeys(pNSObj) into tListNSObj
         -- put ListFromNSArray(tNSObjB) into tList
         if tListNSObj is not nothing then
            log  ["AttributeKeys obj" , tListNSObj]
            put StringFromNSString(tListNSObj) into tStr
            log ["AttributeKeys" , tStr]
         end if
         put c_class_copyPropertyList(tClass,tPropsCount) into tListOpaquePtr
         log ["Props List Count and Pointer", tPropsCount,tListOpaquePtr ]
      end unsafe
   else
      log "No Object"
   end if
end handler
*/
--___________________ END OF DEBUG HANDLERS_________________--

end library

/*
-- Register any notification by name
NotificationObserve "NSProcessInfoThermalStateDidChangeNotification"
NotificationObserve "NSWorkspaceScreensDidSleepNotification"
NotificationObserve "NSWorkspaceScreensDidWakeNotification"

-- A single handler can catch all Notifications:
on notificationReceived pName
   switch pName
      case "NSProcessInfoThermalStateDidChangeNotification"
         put "Thermal state changed" into field "log"
         break
      case "NSWorkspaceScreensDidSleepNotification"
         put "Screen slept" into field "log"
         break
      case "NSWorkspaceScreensDidWakeNotification"
         put "Screen woke" into field "log"
         break
   end switch
end notificationReceived

-- Remove one observer from the list of currently register observers
NotificationRemove "NSWorkspaceScreensDidSleepNotification"

-- Or clean up everything
NotificationRemoveAll

Why This Works So Cleanly
-- addObserverForName:object:queue:usingBlock: returns an opaque token rather than requiring a delegate object,
-- and passing nothing for both object and queue means it matches any sender and delivers on whichever thread posted the notification.
-- The post call in OnNotification then marshals safely back to the LiveCode engine regardless of which thread the notification arrived on.
-- The mObservers array keyed by notification name means you can register as many notifications as you like,
-- each holding its own retention token, all funnelling through the single OnNotification block into the single notificationReceived message.
*/

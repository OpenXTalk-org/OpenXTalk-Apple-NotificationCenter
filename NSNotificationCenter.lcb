/**
Title: Extension Package Handling Utilities

Type: library

Summary: This library enables connecting the scripts to Apple's NSNotificationCenter to register observer callbacks for various API messages.

Version: 1.0.0

Description:

This libarary enables a simply way to connect Apple's NSNotificationCenter to add observers for various messages from Cocoa APIs
observers in order to trigger callbacack messages posted to the engine from the xBuilder Handler, this is done by passiing a
Handler for the ^block (as ObjcBlockPointer), a message then gets posted to the calling Script Object (stack,card,control),
it's a 'callback' to the scripting engine. A list of the currently registered Notification objects is maintained by the module.
NOTE: Many of the AppKit ans NSWindow Notification Names used as examples, may already Handled by the Engine. When the engine
handles the such a message it's translated to traditional xTalk message names such as 'on closeStack'
For examples "NSWindowDidResignMainNotification" is effectively the same message as 'on suspendStack' handler.
and "NSWindowDidBecomeMainNotification" is effectively the same message as that 'on resumeStack' handler would be.
*/

library org.openxtalk.applenotificationcenter
use com.livecode.engine
use com.livecode.foreign
use com.livecode.objc
use com.livecode.array

-- NSNotificationCenter
foreign handler ObjC_NSNotificationCenterDefaultCenter() returns ObjcId binds to "objc:NSNotificationCenter.+defaultCenter"

foreign handler ObjC_AddObserverForName(in pCenter as ObjcId, in pName as optional ObjcId, in pObject as optional ObjcId, in pQueue as optional ObjcId, in pBlock as ObjcBlockPointer) \
	returns ObjcId binds to "objc:NSNotificationCenter.-addObserverForName:object:queue:usingBlock:"

foreign handler ObjC_RemoveObserver(in pCenter as ObjcId, in pObserver as ObjcId) returns nothing binds to "objc:NSNotificationCenter.-removeObserver:"

-- NSNotification
foreign handler ObjC_NotificationName(in pNote as ObjcId) returns ObjcId binds to "objc:NSNotification.-name"

-- NSString
foreign handler ObjC_NSStringWithUTF8String(in pBytes as ZStringNative) returns ObjcId binds to "objc:NSString.+stringWithUTF8String:"
foreign handler ObjC_NSStringUTF8String(in pString as ObjcId) returns ZStringNative binds to "objc:NSString.-UTF8String"

-- Block type matching ^(NSNotification *)
handler type NotificationBlock(in pNote as ObjcId) returns nothing
public variable mBlock as optional ObjcBlockPointer

-- Retained tokens — one per registered notification name
private variable mObservers as optional Array

-- A reference to the calling object (stack,card, or control), to post messages to.
-- This is currently is set each time an observer is registered, but should
-- add handler to allow to explicitly setting this:
private variable mTarget as ScriptObject

-- Central block handler — all notifications funnel through here
public handler OnNotification(in pBlockPointer as ObjcBlockPointer, in pNSNotification as ObjcId) returns nothing
   -- LogNSObjectReflection(pNSNotification)
   variable tName as String
   unsafe
  	 put StringFromNSString( ObjC_NotificationName( pNSNotification ) ) into tName
   end unsafe
	-- log[tName]
   post "notificationReceived" to mTarget with [tName]
end handler

public handler NSNotificationAddObserver(in pName as String) returns nothing
	if pName is not "" then
		put the caller into mTarget
	   variable tToken as optional ObjcObject
	   CreateObjcBlockPointerFromHandler( OnNotification , mBlock)
	   unsafe
			-- You cna pass 'nothing'/nil for pName, but you'll get *ALL* Notifications coming in and probably crash the engine!
		   -- put ObjC_AddObserverForName( ObjC_NSNotificationCenterDefaultCenter(), nothing , nothing, nothing, mBlock) into tToken
		   put ObjC_AddObserverForName( ObjC_NSNotificationCenterDefaultCenter(), StringToNSString( pName ), nothing, nothing, mBlock) into tToken
	   end unsafe
	   if mObservers is nothing then
	      put {} into mObservers
	   end if
	   put tToken into mObservers[pName]
	end if
end handler

public handler NSNotificationRemoveObserver(in pName as String) returns nothing
   if mObservers is nothing then
      return
   end if
   if pName is among the keys of mObservers then
      unsafe
	     ObjC_RemoveObserver(ObjC_NSNotificationCenterDefaultCenter(), mObservers[pName])
        delete mObservers[pName]
		  log "removed observer "&& pName
      end unsafe
   end if
end handler

public handler NSNotificationRemoveAllObservers() returns nothing
	if mBlock is nothing then
		return -- break
	end if
   variable tName as String
   unsafe
	   repeat for each key tName in mObservers
	      ObjC_RemoveObserver( ObjC_NSNotificationCenterDefaultCenter(), mObservers[ tName ] )
			log "removed observer "&& tName
		end repeat
   end unsafe
   put {} into mObservers
	put nothing into mBlock
end handler
/*
